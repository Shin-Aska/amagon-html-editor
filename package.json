{
  "name": "hoarses-html-editor",
  "version": "1.8.1",
  "description": "Amagon — Offline Visual HTML Editor (Pingendo/Mobirise Alternative)",
  "author": "Shin-Aska <Orillarichard@pm.me>",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/electron-vite-dev.mjs",
    "dev:web": "vite",
    "build": "electron-vite build",
    "build:web": "tsc -b && vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "fflate": "^0.8.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.7.0",
    "monaco-editor": "^0.53.0",
    "parse5": "^8.0.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.9.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "minimatch": "^10.2.2"
  },
  "build": {
    "appId": "com.hoarses.editor",
    "productName": "Amagon HTML Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "assets/**/*"
    ],
    "mac": {
      "icon": "assets/app.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "icon": "assets/app.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/app.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "Shin-Aska",
      "repo": "amagon-html-editor",
      "releaseType": "draft"
    }
  }
}