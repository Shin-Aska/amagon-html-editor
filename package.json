{
  "name": "hoarses-html-editor",
  "version": "0.1.0",
  "description": "Amagon — Offline Visual HTML Editor (Pingendo/Mobirise Alternative)",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/electron-vite-dev.mjs",
    "dev:web": "vite",
    "build": "electron-vite build",
    "build:web": "tsc -b && vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.575.0",
    "monaco-editor": "^0.47.0",
    "parse5": "^7.1.2",
    "prettier": "^3.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.9",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^40.6.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.hoarses.editor",
    "productName": "Amagon HTML Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    }
  }
}
